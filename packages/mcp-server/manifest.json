{
  "dxt_version": "0.2",
  "name": "bem-ai-sdk-mcp",
  "version": "0.5.0",
  "description": "The official MCP Server for the Bem API",
  "author": {
    "name": "Bem",
    "email": "contact@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bem-team/bem-typescript-sdk.git"
  },
  "homepage": "https://github.com/bem-team/bem-typescript-sdk/tree/main/packages/mcp-server#readme",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "BEM_API_KEY": "${user_config.BEM_API_KEY}"
      }
    }
  },
  "user_config": {
    "BEM_API_KEY": {
      "title": "api_key",
      "description": "Authenticate using API Key in request header",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
